---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

{/* Lấp lánh — reward sparkle */}
<svg
  viewBox="0 0 100 100"
  aria-hidden="true"
  class:list={[className]}
>
  {/* main 4-pointed sparkle */}
  <path
    d="M50,10 Q53,46 88,50 Q53,54 50,90 Q47,54 12,50 Q47,46 50,10 Z"
    fill="#e89570"
    stroke="#d97950"
    stroke-width="0.8"></path>
  <path
    d="M50,30 Q52,48 70,50 Q52,52 50,70 Q48,52 30,50 Q48,48 50,30 Z"
    fill="#f3c08a"
    opacity="0.9"></path>
  <circle cx="50" cy="50" r="3.5" fill="#fff4dd"></circle>
  {/* tiny side sparkles */}
  <g fill="#e89570">
    <path d="M20,25 l0.8,2.4 2.4,0.8 -2.4,0.8 -0.8,2.4 -0.8,-2.4 -2.4,-0.8 2.4,-0.8 z"></path>
    <path d="M80,75 l0.8,2.4 2.4,0.8 -2.4,0.8 -0.8,2.4 -0.8,-2.4 -2.4,-0.8 2.4,-0.8 z" opacity="0.8"></path>
    <circle cx="82" cy="22" r="1.2" opacity="0.7"></circle>
    <circle cx="18" cy="78" r="1.1" opacity="0.7"></circle>
  </g>
</svg>
