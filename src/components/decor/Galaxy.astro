---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

{/* Thiên hà xoắn — latent space (artistic) */}
<svg
  viewBox="0 0 100 100"
  aria-hidden="true"
  class:list={[className]}
>
  {/* spiral arm 1 (mint) */}
  <path
    d="M50,50 Q63,32 78,40 Q88,55 72,72 Q50,84 28,68 Q15,42 38,22 Q66,12 84,32"
    fill="none"
    stroke="#4f9d83"
    stroke-width="1.5"
    stroke-linecap="round"
    opacity="0.7"></path>
  {/* spiral arm 2 (soft mint) */}
  <path
    d="M50,50 Q40,68 22,62 Q12,45 30,28 Q52,18 72,38"
    fill="none"
    stroke="#6ab39b"
    stroke-width="1.2"
    stroke-linecap="round"
    opacity="0.55"></path>
  {/* center (apricot core) */}
  <circle cx="50" cy="50" r="5" fill="#e89570" opacity="0.9"></circle>
  <circle cx="50" cy="50" r="2" fill="#fff4dd"></circle>
  {/* dots along spiral */}
  <g fill="#4f9d83">
    <circle cx="62" cy="35" r="1.6" opacity="0.85"></circle>
    <circle cx="74" cy="50" r="1.4" opacity="0.75"></circle>
    <circle cx="64" cy="68" r="1.3" opacity="0.65"></circle>
    <circle cx="42" cy="70" r="1.1" opacity="0.55"></circle>
    <circle cx="28" cy="55" r="1.3" opacity="0.7"></circle>
    <circle cx="34" cy="35" r="1.1" opacity="0.6"></circle>
    <circle cx="50" cy="28" r="1.4" opacity="0.75"></circle>
  </g>
  {/* outer scatter */}
  <g fill="#e89570" opacity="0.6">
    <circle cx="13" cy="28" r="1"></circle>
    <circle cx="88" cy="68" r="1"></circle>
    <circle cx="20" cy="82" r="0.8"></circle>
    <circle cx="82" cy="14" r="0.7"></circle>
  </g>
</svg>
