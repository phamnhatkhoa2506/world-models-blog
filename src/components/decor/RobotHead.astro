---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

{/* Đầu robot dễ thương — agent */}
<svg
  viewBox="0 0 100 100"
  aria-hidden="true"
  class:list={[className]}
>
  {/* antenna */}
  <line
    x1="50"
    y1="22"
    x2="50"
    y2="32"
    stroke="#4f9d83"
    stroke-width="1.5"
    stroke-linecap="round"></line>
  <circle
    cx="50"
    cy="18"
    r="3.5"
    fill="#e89570"
    stroke="#d97950"
    stroke-width="0.8"></circle>
  {/* ear bolts */}
  <rect
    x="20"
    y="50"
    width="5"
    height="12"
    rx="1.5"
    fill="#4f9d83"></rect>
  <rect
    x="75"
    y="50"
    width="5"
    height="12"
    rx="1.5"
    fill="#4f9d83"></rect>
  {/* head */}
  <rect
    x="24"
    y="32"
    width="52"
    height="44"
    rx="9"
    fill="#6ab39b"
    stroke="#4f9d83"
    stroke-width="1.5"></rect>
  {/* screen panel */}
  <rect
    x="31"
    y="38"
    width="38"
    height="24"
    rx="3"
    fill="#fbfaf7"
    stroke="#4f9d83"
    stroke-width="0.7"></rect>
  {/* eyes */}
  <circle cx="41" cy="50" r="3.2" fill="#4f9d83"></circle>
  <circle cx="59" cy="50" r="3.2" fill="#4f9d83"></circle>
  <circle cx="42" cy="49" r="1" fill="#fbfaf7"></circle>
  <circle cx="60" cy="49" r="1" fill="#fbfaf7"></circle>
  {/* smile */}
  <path
    d="M42,57 Q50,60 58,57"
    fill="none"
    stroke="#4f9d83"
    stroke-width="1.4"
    stroke-linecap="round"></path>
  {/* cheeks */}
  <circle cx="33" cy="58" r="1.5" fill="#e89570" opacity="0.55"></circle>
  <circle cx="67" cy="58" r="1.5" fill="#e89570" opacity="0.55"></circle>
  {/* neck/body hint */}
  <rect x="42" y="76" width="16" height="6" fill="#4f9d83"></rect>
  <rect
    x="33"
    y="82"
    width="34"
    height="9"
    rx="2.5"
    fill="#6ab39b"
    stroke="#4f9d83"
    stroke-width="1.2"></rect>
  <circle cx="42" cy="86.5" r="1.2" fill="#e89570"></circle>
  <circle cx="50" cy="86.5" r="1.2" fill="#e89570"></circle>
  <circle cx="58" cy="86.5" r="1.2" fill="#e89570"></circle>
</svg>
