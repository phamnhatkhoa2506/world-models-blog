---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

{/* Quả cầu pha lê chứa landscape — world model dreaming */}
<svg
  viewBox="0 0 100 100"
  aria-hidden="true"
  class:list={[className]}
>
  {/* base/stand */}
  <ellipse cx="50" cy="93" rx="22" ry="3.5" fill="#a8896b" opacity="0.7"></ellipse>
  <path d="M33,80 L40,90 L60,90 L67,80 Z" fill="#a8896b"></path>
  <line
    x1="33"
    y1="80"
    x2="67"
    y2="80"
    stroke="#8a6f55"
    stroke-width="1"></line>
  {/* ball */}
  <circle
    cx="50"
    cy="52"
    r="30"
    fill="#fbfaf7"
    stroke="#4f9d83"
    stroke-width="1.5"></circle>
  {/* mini landscape inside */}
  <g transform="translate(30,52)" clip-path="circle(28 at 20 0)">
    <path
      d="M-2,18 L8,5 L14,12 L22,2 L30,14 L36,8 L42,18 Z"
      fill="#6ab39b"
      opacity="0.85"></path>
    <path
      d="M16,18 L22,9 L26,13 L34,5 L42,18 Z"
      fill="#4f9d83"
      opacity="0.6"></path>
    {/* "dream" stars inside */}
    <circle cx="6" cy="-4" r="0.9" fill="#e89570"></circle>
    <circle cx="22" cy="-8" r="1" fill="#e89570"></circle>
    <circle cx="35" cy="-2" r="0.8" fill="#e89570"></circle>
  </g>
  {/* glass highlight */}
  <ellipse
    cx="40"
    cy="40"
    rx="7"
    ry="3"
    fill="#ffffff"
    opacity="0.8"
    transform="rotate(-30 40 40)"></ellipse>
  {/* sparkles around */}
  <g fill="#e89570">
    <path d="M50,17 l0.8,2.2 2.2,0.8 -2.2,0.8 -0.8,2.2 -0.8,-2.2 -2.2,-0.8 2.2,-0.8 z"></path>
    <circle cx="80" cy="38" r="1.3"></circle>
    <circle cx="20" cy="38" r="1.1"></circle>
    <circle cx="83" cy="62" r="0.9" opacity="0.7"></circle>
  </g>
</svg>
