---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

{/* Quỹ đạo — RL loop (agent ↻ environment) */}
<svg
  viewBox="0 0 100 100"
  aria-hidden="true"
  class:list={[className]}
>
  {/* orbital ellipse */}
  <ellipse
    cx="50"
    cy="50"
    rx="40"
    ry="22"
    fill="none"
    stroke="#4f9d83"
    stroke-width="1.4"
    stroke-dasharray="3 3"
    transform="rotate(-15 50 50)"></ellipse>
  {/* secondary tilted orbit */}
  <ellipse
    cx="50"
    cy="50"
    rx="35"
    ry="18"
    fill="none"
    stroke="#6ab39b"
    stroke-width="0.7"
    opacity="0.5"
    transform="rotate(25 50 50)"></ellipse>
  {/* environment center (mint planet) */}
  <circle
    cx="50"
    cy="50"
    r="11"
    fill="#6ab39b"
    stroke="#4f9d83"
    stroke-width="1.4"></circle>
  <circle cx="46" cy="46" r="3" fill="#84d4b8" opacity="0.8"></circle>
  <circle cx="55" cy="53" r="1.5" fill="#4f9d83"></circle>
  {/* agent orbiting */}
  <circle
    cx="76"
    cy="32"
    r="5.5"
    fill="#e89570"
    stroke="#d97950"
    stroke-width="1"></circle>
  <circle cx="78" cy="30" r="1.5" fill="#fff4dd"></circle>
  {/* direction arrow */}
  <path
    d="M86,55 Q92,45 86,35"
    fill="none"
    stroke="#e89570"
    stroke-width="1.5"
    stroke-linecap="round"></path>
  <path
    d="M86,35 L82,36 M86,35 L88,39"
    stroke="#e89570"
    stroke-width="1.5"
    stroke-linecap="round"></path>
  {/* small dots — trace */}
  <g fill="#4f9d83" opacity="0.5">
    <circle cx="20" cy="62" r="1.1"></circle>
    <circle cx="32" cy="74" r="1"></circle>
    <circle cx="65" cy="20" r="1"></circle>
  </g>
</svg>
