---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

{/* La bàn — exploration vs exploitation */}
<svg
  viewBox="0 0 100 100"
  aria-hidden="true"
  class:list={[className]}
>
  <circle
    cx="50"
    cy="50"
    r="44"
    fill="#fbfaf7"
    stroke="#4f9d83"
    stroke-width="1.5"></circle>
  <circle
    cx="50"
    cy="50"
    r="36"
    fill="none"
    stroke="#4f9d83"
    stroke-width="0.7"
    stroke-dasharray="2 2"
    opacity="0.7"></circle>
  {/* diagonal small ticks */}
  <g
    stroke="#4f9d83"
    stroke-width="0.6"
    opacity="0.6"
  >
    <line x1="29" y1="29" x2="33" y2="33"></line>
    <line x1="71" y1="29" x2="67" y2="33"></line>
    <line x1="29" y1="71" x2="33" y2="67"></line>
    <line x1="71" y1="71" x2="67" y2="67"></line>
  </g>
  {/* horizontal needle (orange) */}
  <polygon
    points="14,50 50,46 86,50 50,54"
    fill="#e89570"
    opacity="0.9"></polygon>
  {/* vertical needle (mint, on top) */}
  <polygon points="50,10 56,50 50,90 44,50" fill="#4f9d83"></polygon>
  <polygon points="50,10 50,50 44,50" fill="#3d7e69"></polygon>
  {/* center pivot */}
  <circle
    cx="50"
    cy="50"
    r="3.5"
    fill="#fbfaf7"
    stroke="#2a2a2a"
    stroke-width="1.2"></circle>
  <circle cx="50" cy="50" r="1" fill="#2a2a2a"></circle>
  {/* N label */}
  <text
    x="50"
    y="8"
    text-anchor="middle"
    font-size="6"
    font-family="serif"
    font-style="italic"
    fill="#4f9d83">N</text>
</svg>
