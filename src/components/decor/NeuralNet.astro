---
interface Props {
  class?: string;
}
const { class: className = "" } = Astro.props;
---

<svg
  viewBox="0 0 140 140"
  fill="none"
  stroke="currentColor"
  stroke-linecap="round"
  aria-hidden="true"
  class:list={["text-accent", className]}
>
  <!-- 3-layer feedforward wireframe: 3 → 4 → 2 -->
  {/* edges layer 1 -> 2 */}
  <g stroke-width="0.6" opacity="0.35">
    <line x1="20" y1="35" x2="70" y2="20"></line>
    <line x1="20" y1="35" x2="70" y2="55"></line>
    <line x1="20" y1="35" x2="70" y2="90"></line>
    <line x1="20" y1="35" x2="70" y2="125"></line>
    <line x1="20" y1="70" x2="70" y2="20"></line>
    <line x1="20" y1="70" x2="70" y2="55"></line>
    <line x1="20" y1="70" x2="70" y2="90"></line>
    <line x1="20" y1="70" x2="70" y2="125"></line>
    <line x1="20" y1="105" x2="70" y2="20"></line>
    <line x1="20" y1="105" x2="70" y2="55"></line>
    <line x1="20" y1="105" x2="70" y2="90"></line>
    <line x1="20" y1="105" x2="70" y2="125"></line>
  </g>
  {/* edges layer 2 -> 3 */}
  <g stroke-width="0.8" opacity="0.55">
    <line x1="70" y1="20" x2="120" y2="55"></line>
    <line x1="70" y1="20" x2="120" y2="90"></line>
    <line x1="70" y1="55" x2="120" y2="55"></line>
    <line x1="70" y1="55" x2="120" y2="90"></line>
    <line x1="70" y1="90" x2="120" y2="55"></line>
    <line x1="70" y1="90" x2="120" y2="90"></line>
    <line x1="70" y1="125" x2="120" y2="55"></line>
    <line x1="70" y1="125" x2="120" y2="90"></line>
  </g>
  {/* nodes */}
  <g fill="currentColor" stroke="none">
    <circle cx="20" cy="35" r="4" opacity="0.75"></circle>
    <circle cx="20" cy="70" r="4" opacity="0.75"></circle>
    <circle cx="20" cy="105" r="4" opacity="0.75"></circle>
    <circle cx="70" cy="20" r="3.5" opacity="0.85"></circle>
    <circle cx="70" cy="55" r="3.5" opacity="0.85"></circle>
    <circle cx="70" cy="90" r="3.5" opacity="0.85"></circle>
    <circle cx="70" cy="125" r="3.5" opacity="0.85"></circle>
    <circle cx="120" cy="55" r="4.5"></circle>
    <circle cx="120" cy="90" r="4.5"></circle>
  </g>
</svg>
